# Copy to `.env` and fill in values. Never commit real `.env` to git.

# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth (required — app throws if missing)
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: search / integrations
TAVILY_API_KEY=

# AWS S3 (uploads)
AWS_S3_REGION=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
